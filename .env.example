# =============================================================================
# Rate Limiter MVP — Environment Variables
# =============================================================================
# Copy this file to `.env` and adjust values as needed.
#   cp .env.example .env
#
# All settings are read by pydantic-settings with prefix RATELIMIT_.
# Unset variables fall back to app defaults (shown below).

# --- Server ---------------------------------------------------------------

# Bind address inside the container (always 0.0.0.0 for Docker).
RATELIMIT_HOST=0.0.0.0

# Port the uvicorn process listens on inside the container.
# docker-compose maps APP_PORT (host) to this port (container).
RATELIMIT_PORT=8000

# --- Rate Limiting Defaults -----------------------------------------------

# Default max requests per client per window.
RATELIMIT_DEFAULT_LIMIT=100

# Default window length (seconds) for rate-limit evaluation.
RATELIMIT_DEFAULT_WINDOW_SEC=60

# Default burst allowance (token bucket only) — peak requests allowed above
# the sustained rate in a short interval.
RATELIMIT_DEFAULT_BURST=100

# How often (seconds) the cleanup sweep runs for stale lock entries.
RATELIMIT_LOCK_CLEANUP_INTERVAL_SEC=60

# How long (seconds) before an idle token-bucket entry is eligible for cleanup.
RATELIMIT_BUCKET_IDLE_TTL_SEC=300

# --- Redis (future) --------------------------------------------------------
# Uncomment when using the Redis backend.
# RATELIMIT_REDIS_URL=redis://localhost:6379/0
